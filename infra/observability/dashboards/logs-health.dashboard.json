{
  "title": "SBN Logs Health",
  "uid": "sbn-logs-health",
  "tags": ["sbn", "logs", "sprint4"],
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Error Logs by Service (5m)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(log_entries_total{severity=\"error\"}[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Incident Correlation Coverage",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(log_entries_total{incident_correlation_id_present=\"true\"}[5m])) / clamp_min(sum(rate(log_entries_total[5m])), 1)",
          "legendFormat": "coverage_ratio"
        }
      ]
    },
    {
      "id": 3,
      "title": "Structured Logging Parse Failures",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(log_parse_failures_total[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
