{
  "title": "SBN Metrics Overview",
  "uid": "sbn-metrics-overview",
  "tags": ["sbn", "metrics", "sprint4"],
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Opportunity Throughput (5m)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(opportunity_computed_total[5m]))",
          "legendFormat": "opportunities/sec"
        }
      ]
    },
    {
      "id": 2,
      "title": "Decision Latency p95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(decision_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "decision_latency_ms_p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Dispatch Latency p95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(dispatch_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "dispatch_latency_ms_p95"
        }
      ]
    },
    {
      "id": 4,
      "title": "Provider Error Rate by Source",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(provider_request_errors_total[5m])) by (provider)",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Prediction Ingestion Lag p95 (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ingestion_lag_ms_bucket{pipeline=\"prediction_markets\"}[5m])) by (le))",
          "legendFormat": "ingestion_lag_ms_p95"
        }
      ]
    },
    {
      "id": 6,
      "title": "Quote Integrity Failure Ratio",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(quote_integrity_failures_total[5m])) / clamp_min(sum(rate(quote_integrity_checks_total[5m])), 1)",
          "legendFormat": "quote_integrity_failure_ratio"
        }
      ]
    },
    {
      "id": 7,
      "title": "Stale Quotes by Venue (5m)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(stale_quote_rejections_total[5m])) by (venue)",
          "legendFormat": "{{venue}}"
        }
      ]
    }
  ]
}
